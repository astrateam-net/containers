#!/usr/bin/env node
// Force Docmost Enterprise on. Single seam: the EE LicenseService (compiled
// dist/ee/licence/license.service.js). Both license guards (FeatureGuard,
// LicenseGuard) inject this exact service, and the open-source LicenseCheckService
// delegates to it, which in turn feeds POST /workspace/entitlements -> the client's
// useHasFeature() reads that. So patching these four read methods unlocks the whole
// app (UI badges, backend route guards, share controller) with NO license key:
//
//   isValidEELicense() -> true          (license/enterprise-only route guards pass)
//   hasFeature()       -> true          (every Feature.* allowed)
//   getFeatures()      -> all enterprise features (entitlements.features = full set)
//   getLicenseType()   -> 'enterprise'  (entitlements.tier = enterprise)
//
// getFeatures pulls the list from the app's own feature-registry ('enterprise' tier)
// so newly-added enterprise features are included automatically on version bumps.
// Each patch asserts it matched -> build fails loud if an anchor moves.

const fs = require("fs");
const path = require("path");

const ROOT = "/app/apps/server/dist";

const PATCHES = [
  {
    name: "isValidEELicense",
    needle: "isValidEELicense(licenseKey) {",
    replacement: "isValidEELicense(licenseKey) { return true;",
  },
  {
    name: "hasFeature",
    needle: "hasFeature(licenseKey, feature) {",
    replacement: "hasFeature(licenseKey, feature) { return true;",
  },
  {
    name: "getFeatures",
    needle: "getFeatures(licenseKey) {",
    replacement:
      'getFeatures(licenseKey) { return [...require("./feature-registry").getFeaturesForLicenseType("enterprise")];',
  },
  {
    name: "getLicenseType",
    needle: "getLicenseType(licenseKey) {",
    replacement: 'getLicenseType(licenseKey) { return "enterprise";',
  },
];

function licenseServiceFiles(dir, out) {
  for (const e of fs.readdirSync(dir, { withFileTypes: true })) {
    const p = path.join(dir, e.name);
    if (e.isDirectory()) licenseServiceFiles(p, out);
    else if (e.name === "license.service.js") out.push(p);
  }
  return out;
}

const files = licenseServiceFiles(ROOT, []);
for (const patch of PATCHES) {
  let hits = 0;
  for (const f of files) {
    const src = fs.readFileSync(f, "utf8");
    if (!src.includes(patch.needle)) continue;
    fs.writeFileSync(f, src.split(patch.needle).join(patch.replacement));
    hits++;
  }
  if (hits === 0) {
    throw new Error(`astrawiki: anchor for ${patch.name} not found`);
  }
  console.log(`astrawiki: ${patch.name} patched in ${hits} file(s)`);
}

// ---- MCP OAuth broker: mount into the compiled server -----------------------
// Stock Docmost gates /mcp behind a static API-key bearer with no OAuth flow, so
// native web MCP connectors (Claude, ChatGPT) can't authenticate. The broker
// (dist/mcp-oauth/broker.js, COPYed in by the Dockerfile) turns Docmost into its
// own OAuth AS+RS and delegates login to the existing Authentik OIDC provider.
// We require + invoke it just before app.listen() so its Fastify routes register
// before the server goes live. Anchor asserted -> build fails loud if it moves.
const brokerFile = path.join(ROOT, "mcp-oauth", "broker.js");
if (!fs.existsSync(brokerFile)) {
  throw new Error(`astrawiki: broker not found at ${brokerFile} (Dockerfile must COPY it before running the agent)`);
}

const mainFile = path.join(ROOT, "main.js");
let main = fs.readFileSync(mainFile, "utf8");

const INJECT_ANCHOR = "    const port = process.env.PORT || 3000;";
const INJECT_LINE =
  '    try { require("./mcp-oauth/broker").registerMcpOauth(app); } catch (e) { new (require("@nestjs/common").Logger)("McpOAuth").error("MCP OAuth broker failed to mount", e); }';

if (main.includes("./mcp-oauth/broker")) {
  console.log("astrawiki: broker already wired into main.js (skipping)");
} else {
  if (!main.includes(INJECT_ANCHOR)) {
    throw new Error("astrawiki: bootstrap anchor (app.listen port line) not found in main.js");
  }
  main = main.replace(INJECT_ANCHOR, `${INJECT_LINE}\n${INJECT_ANCHOR}`);
  fs.writeFileSync(mainFile, main);
  console.log("astrawiki: MCP OAuth broker wired into main.js");
}

// ---- 3. UPSTREAM BUGFIX: MCP list pagination NaN ----------------------------
// Stock Docmost's MCP list tools call the paginated services WITHOUT a limit
// (list_child_pages has no limit param at all), so cursor-pagination computes
// `undefined + 1 = NaN` -> `LIMIT NaN` -> Postgres "invalid input syntax for
// type bigint: NaN". The HTTP API never hits it because its PaginationOptions
// DTO defaults limit to 20; the MCP path bypasses that DTO. Two targeted fixes,
// matching Docmost's own behaviour (not inventing a new limit):
//   a) cursor-pagination: default perPage to 20 (Docmost's canonical default)
//      when it isn't a positive integer -> fixes every MCP list tool at once.
//   b) list_child_pages: expose a `limit` param (min 1 / max 100) and pass it
//      through, so clients can size the page like the sidebar tree does. Cursor
//      paging already worked; only the limit knob was missing.
const FILE_PATCHES = [
  {
    file: "database/pagination/cursor-pagination.js",
    name: "pagination-default-limit",
    skipIf: "opts.perPage = 20;",
    needle: "    const rows = await qb.limit(opts.perPage + 1).execute();",
    replacement:
      "    if (!Number.isInteger(opts.perPage) || opts.perPage <= 0) opts.perPage = 20;\n    const rows = await qb.limit(opts.perPage + 1).execute();",
  },
  {
    file: "ee/mcp/tools/page.tools.js",
    name: "list_child_pages-limit-schema",
    skipIf: "Number of child pages per page",
    needle: "                .describe('Parent page ID to list children of'),",
    replacement:
      "                .describe('Parent page ID to list children of'),\n            limit: v4_1.z.number().int().min(1).max(100).optional().describe('Number of child pages per page (default 20, max 100)'),",
  },
  {
    file: "ee/mcp/tools/page.tools.js",
    name: "list_child_pages-limit-passthrough",
    skipIf: "{ cursor: args.cursor, limit: args.limit }",
    needle: "getSidebarPages(spaceId, { cursor: args.cursor }, args.pageId, user.id, spaceCanEdit)",
    replacement: "getSidebarPages(spaceId, { cursor: args.cursor, limit: args.limit }, args.pageId, user.id, spaceCanEdit)",
  },
];

for (const p of FILE_PATCHES) {
  const fp = path.join(ROOT, p.file);
  const src = fs.readFileSync(fp, "utf8");
  if (p.skipIf && src.includes(p.skipIf)) {
    console.log(`astrawiki: ${p.name} already applied (skipping)`);
    continue;
  }
  if (!src.includes(p.needle)) {
    throw new Error(`astrawiki: anchor for ${p.name} not found in ${p.file}`);
  }
  fs.writeFileSync(fp, src.split(p.needle).join(p.replacement));
  console.log(`astrawiki: ${p.name} patched`);
}
