#!/bin/bash
set -eu

BACKUP_NAME="${1:?Usage: backup-restore <backup-name> [target-dir]}"
TARGET_DIR="${2:-/tmp/restore}"

echo "[$(date -Iseconds)] Restoring: ${BACKUP_NAME} -> ${TARGET_DIR}"
mkdir -p "${TARGET_DIR}"

xbcloud get --storage=s3 \
    --s3-endpoint="${S3_ENDPOINT}" \
    --s3-access-key="${S3_ACCESS_KEY}" \
    --s3-secret-key="${S3_SECRET_KEY}" \
    --s3-bucket="${S3_BUCKET}" \
    --s3-bucket-lookup="${S3_BUCKET_LOOKUP}" \
    "${BACKUP_NAME}" | xbstream -xv -C "${TARGET_DIR}"

xtrabackup --prepare --target-dir="${TARGET_DIR}"

echo "[$(date -Iseconds)] Restore completed: ${TARGET_DIR}"
