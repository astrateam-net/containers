#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const ROOT = "/usr/local/lib/node_modules/n8n";

const PATCHES = [
  {
    name: "isLicensed",
    needle: "return this.manager?.hasFeatureEnabled(feature) ?? false;",
    replacement:
      "return feature!=='feat:showNonProdBanner'&&feature!=='feat:apiDisabled';",
  },
  {
    name: "getValue",
    needle: "return this.manager?.getFeatureValue(feature);",
    replacement:
      "return (typeof feature==='string'&&feature.startsWith('quota:'))?-1:this.manager?.getFeatureValue(feature);",
  },
];

function licenseJsFiles(dir, out) {
  for (const e of fs.readdirSync(dir, { withFileTypes: true })) {
    const p = path.join(dir, e.name);
    if (e.isDirectory()) licenseJsFiles(p, out);
    else if (e.name.endsWith(".js") && e.name.includes("license")) out.push(p);
  }
  return out;
}

const files = licenseJsFiles(ROOT, []);
for (const patch of PATCHES) {
  let hits = 0;
  for (const f of files) {
    const src = fs.readFileSync(f, "utf8");
    if (!src.includes(patch.needle)) continue;
    fs.writeFileSync(f, src.split(patch.needle).join(patch.replacement));
    hits++;
  }
  if (hits === 0) {
    throw new Error(`astraflow: anchor for ${patch.name} not found`);
  }
  console.log(`astraflow: ${patch.name} patched in ${hits} file(s)`);
}
