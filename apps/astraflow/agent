#!/usr/bin/env node
// Force n8n Enterprise on: License.isLicensed() -> true for every feature EXCEPT
// two inverted flags where licensed==true is a restriction, not a perk:
//   feat:showNonProdBanner -> shows the "not licensed for production" nag banner
//   feat:apiDisabled       -> disables the public REST API (isApiEnabled checks it)
// Every check (old isXEnabled + new LicenseState) funnels through isLicensed and the
// frontend derives from the backend, so this one edit is enough. Throws if anchor moves.

const fs = require("fs");
const path = require("path");

const ROOT = "/usr/local/lib/node_modules/n8n";
const NEEDLE = "return this.manager?.hasFeatureEnabled(feature) ?? false;";
const PATCH =
  "return feature!=='feat:showNonProdBanner'&&feature!=='feat:apiDisabled';";

function licenseJsFiles(dir, out) {
  for (const e of fs.readdirSync(dir, { withFileTypes: true })) {
    const p = path.join(dir, e.name);
    if (e.isDirectory()) licenseJsFiles(p, out);
    else if (e.name.endsWith(".js") && e.name.includes("license")) out.push(p);
  }
  return out;
}

let patched = 0;
for (const f of licenseJsFiles(ROOT, [])) {
  const src = fs.readFileSync(f, "utf8");
  if (!src.includes(NEEDLE)) continue;
  fs.writeFileSync(f, src.split(NEEDLE).join(PATCH));
  patched++;
}

if (patched === 0) {
  throw new Error("astraflow: License.isLicensed anchor not found");
}
console.log(`astraflow: enterprise fix applied to ${patched} file(s)`);
