#!/usr/bin/env python3
# Fix Enterprise gating: force status() -> VALID and forge cached_summary().
# Backend and web UI both gate on summary.status; the forged summary also
# skips the cached copy (authentik caches it in Postgres). Asserts fail
# the build if an anchor moves.

from pathlib import Path

LICENSE = Path("/authentik/enterprise/license.py")

STATUS_ANCHOR = "    def status(self) -> LicenseUsageStatus:\n"
STATUS_PATCH = "        return LicenseUsageStatus.VALID\n"

SUMMARY_ANCHOR = "    def cached_summary() -> LicenseSummary:\n"
SUMMARY_PATCH = """\
        from datetime import datetime, timezone
        return LicenseSummary(
            internal_users=999999,
            external_users=999999,
            status=LicenseUsageStatus.VALID,
            latest_valid=datetime(2099, 12, 31, tzinfo=timezone.utc),
            license_flags=[],
        )
"""


def main() -> None:
    src = LICENSE.read_text()

    assert STATUS_ANCHOR in src, "status() anchor moved"
    src = src.replace(STATUS_ANCHOR, STATUS_ANCHOR + STATUS_PATCH, 1)

    assert SUMMARY_ANCHOR in src, "cached_summary() anchor moved"
    src = src.replace(SUMMARY_ANCHOR, SUMMARY_ANCHOR + SUMMARY_PATCH, 1)

    LICENSE.write_text(src)
    print("astra-sso: enterprise fix applied")


if __name__ == "__main__":
    main()
