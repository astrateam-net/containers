@@ -883,6 +884,26 @@ func (api *API) updateEntitlements(ctx context.Context) error {
 			return codersdk.Entitlements{}, entitlements.ErrLicenseRequiresTelemetry
 		}
 
+		// Locally entitle every feature. The enterprise code paths are all
+		// compiled into this binary; this removes the entitlement barrier and
+		// leaves the on/off decision to deployment config (and AlwaysEnable
+		// features). Limit features are given an effectively unlimited cap so
+		// usage checks pass.
+		reloadedEntitlements.HasLicense = true
+		reloadedEntitlements.Errors = []string{}
+		for _, name := range codersdk.FeatureNames {
+			f := reloadedEntitlements.Features[name]
+			f.Entitlement = codersdk.EntitlementEntitled
+			if name.UsesLimit() {
+				unlimited := int64(1) << 40
+				f.Enabled = true
+				f.Limit = &unlimited
+			} else {
+				f.Enabled = enablements[name] || name.AlwaysEnable()
+			}
+			reloadedEntitlements.Features[name] = f
+		}
+
